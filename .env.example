# Flask Configuration
FLASK_APP=backend/run.py
FLASK_ENV=development
FLASK_SECRET_KEY=
DATABASE_URL=sqlite:///orbit.db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

